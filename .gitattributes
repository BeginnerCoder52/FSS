* text=auto eol=lf

# Force bash scripts to always have LF
*.sh text eol=lf

# Source code files
*.py text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.h text eol=lf
*.c text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Exclude binary files
*.tflite binary
*.png binary
*.jpg binary
*.jpeg binary
*.db binary
