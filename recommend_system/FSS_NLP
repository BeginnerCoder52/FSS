ype\": \"number\",\n        \"std\": 2,\n        \"min\": 2,\n        \"max\": 11,\n        \"num_unique_values\": 4,\n        \"samples\": [\n          4,\n          11,\n          3\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"Raw_Text\",\n      \"properties\": {\n        \"dtype\": \"string\",\n        \"num_unique_values\": 10,\n        \"samples\": [\n          \"RAU N\\u00caM : H\\u00e0nh_l\\u00e1\",\n          \"B\\u1eafp b\\u00f2 hoa 200g\",\n          \"N\\u1ea5m_r\\u01a1m 100g\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"}},"metadata":{}}]},{"cell_type":"markdown","source":["## GIAI ĐOẠN 3: LỰA CHỌN KIẾN TRÚC MÔ HÌNH NLP CHO THIẾT BỊ BIÊN (MODEL SELECTION)\n","\n","\n","\n"],"metadata":{"id":"3dLJf9yMP4C8"}},{"cell_type":"markdown","source":["### 3.1. Phân tích so sánh các kiến trúc ứng viên\n","Dựa trên lý thuyết Thiết kế hệ thống Machine Learning phục vụ thiết bị nhúng (Edge AI Workflow), hai kiến trúc tối ưu được đưa vào cân nhắc:\n","1. **Kiến trúc thống kê tuyến tính (Conditional Random Fields - CRF):** Ưu điểm là tính toán cực kỳ nhanh, trọng số chỉ vài megabyte, không yêu cầu phần cứng mạnh, tối ưu tốt cho các cấu trúc văn bản ngắn và có quy luật rõ ràng như danh sách nguyên liệu.\n","2. **Kiến trúc Transformer thu gọn (PhoBERT-tiny / MobileBERT):** Khả năng học ngữ cảnh tiếng Việt xuất sắc nhờ cơ chế Self-Attention, nhưng yêu cầu tài nguyên bộ nhớ cao hơn cấu trúc CRF."],"metadata":{"id":"dFqg-2gqwn0q"}},{"cell_type":"code","source":["# 1. Fix Colab Logger Issue & Import ML Libraries\n","# -----------------------------------------------------------------------------\n","import sys\n","import logging\n","import sklearn_crfsuite\n","from sklearn_crfsuite import metrics\n","\n","# Force Colab to print logs by adding a StreamHandler to stdout\n","if not logger.handlers:\n","    handler = logging.StreamHandler(sys.stdout)\n","    formatter = logging.Formatter('%(asctime)s - %(name)s - %(levelname)s - [%(funcName)s] - %(message)s')\n","    handler.setFormatter(formatter)\n","    logger.addHandler(handler)\n","    logger.setLevel(logging.INFO)\n","\n","logger.info(\"Logger đã được cấu hình thành công trên Colab. Bắt đầu Giai đoạn 3.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"9eLnc_KxwpYI","executionInfo":{"status":"ok","timestamp":1779041253080,"user_tz":-420,"elapsed":16,"user":{"displayName":"Hien Coder","userId":"07457395390073418186"}},"outputId":"d904e953-39c1-454c-9cdd-c7c5465937cf"},"execution_count":25,"outputs":[{"output_type":"stream","name":"stdout","text":["2026-05-17 18:07:32,949 - FSS_NLP_Phase1 - INFO - [<cell line: 0>] - Logger đã được cấu hình thành công trên Colab. Bắt đầu Giai đoạn 3.\n"]},{"output_type":"stream","name":"stderr","text":["INFO:FSS_NLP_Phase1:Logger đã được cấu hình thành công trên Colab. Bắt đầu Giai đoạn 3.\n"]}]},{"cell_type":"markdown","source":["### 3.2. Xây dựng Thuật toán Gán nhãn tự động (Heuristic BIO Annotator)\n","* Trong thực tế, để huấn luyện mô hình nhận dạng thực thể (NER), chúng ta cần hàng ngàn câu đã được gán nhãn thủ công (Data Annotation).\n","* Để tự động hóa tiến trình này, hệ thống áp dụng kỹ thuật **Heuristic Rules** (Luật theo kinh nghiệm) dựa trên các từ chỉ đơn vị đo lường phổ biến trong ẩm thực Việt Nam (Ví dụ: *gam, kg, muỗng, trái, con*...). Thuật toán sẽ quét mảng `raw_corpus` đã làm sạch ở Giai đoạn 2 và tự động gán thẻ định dạng `B-ING, I-ING, B-QTY, I-QTY` cho từng token."],"metadata":{"id":"NYorqMtPwu4f"}},{"cell_type":"code","source":["# 2. Heuristic BIO Annotator (Auto Labeling)\n","# -----------------------------------------------------------------------------\n","# Tập hợp các từ khóa định lượng phổ biến trong công thức ẩm thực Việt Nam\n","QUANTITY_UNITS = {\n","    \"g\", \"kg\", \"ml\", \"lít\", \"muỗng\", \"thìa\", \"m\", \"chén\", \"tô\",\n","    \"trái\", \"quả\", \"con\", \"củ\", \"nhánh\", \"tép\", \"lát\", \"gram\", \"cọng\", \"cây\"\n","}\n","\n","def auto_bio_tagger(token_list: List[str]) -> List[tuple]:\n","    \"\"\"\n","    Applies heuristic rules to auto-generate BIO tags for a sequence of tokens.\n","\n","    Args:\n","        token_list (List[str]): Cleaned tokens from Phase 2.\n","    Returns:\n","        List[tuple]: List of (Word, Tag) tuples suitable for CRF training.\n","    \"\"\"\n","    tagged_sentence = []\n","\n","    for token in token_list:\n","        # Check if the token is a number or contains a known measurement unit\n","        is_qty = token.isdigit() or any(unit in token.lower() for unit in QUANTITY_UNITS) or bool(re.search(r'\\d', token))\n","\n","        if is_qty:\n","            # Simple heuristic: If it has numbers/units, label as Quantity\n","            if not tagged_sentence or tagged_sentence[-1][1] not in (fss_config.tags.B_QTY, fss_config.tags.I_QTY):\n","                tag = fss_config.tags.B_QTY\n","            else:\n","                tag = fss_config.tags.I_QTY\n","        else:\n","            # Otherwise, consider it an Ingredient name\n","            # Ignore special characters or single letters\n","            if len(token) <= 1 and not token.isalnum():\n","                tag = fss_config.tags.O\n","            elif not tagged_sentence or tagged_sentence[-1][1] not in (fss_config.tags.B_ING, fss_config.tags.I_ING):\n","                tag = fss_config.tags.B_ING\n","            else:\n","                tag = fss_config.tags.I_ING\n","\n","        tagged_sentence.append((token, tag))\n","\n","    return tagged_sentence\n","\n","def annotate_corpus(corpus: List[str]) -> List[List[tuple]]:\n","    \"\"\"Generates the full labeled dataset for model training.\"\"\"\n","    logger.info(\"Bắt đầu quá trình gán nhãn BIO tự động (Heuristic Annotation)...\")\n","    labeled_data = []\n","    for sequence in corpus:\n","        # sequence is a string like \"1 con mực_khô\", split it into tokens\n","        tokens = sequence.split()\n","        tagged_seq = auto_bio_tagger(tokens)\n","        if tagged_seq:\n","            labeled_data.append(tagged_seq)\n","\n","    logger.info(f\"Hoàn tất gán nhãn cho {len(labeled_data)} mẫu dữ liệu.\")\n","    return labeled_data\n","\n","# Execute Annotation\n","labeled_dataset = annotate_corpus(raw_corpus)\n","# In ra 3 mẫu thử nghiệm để kiểm chứng\n","logger.info(f\"Mẫu gán nhãn (Sample 1): {labeled_dataset[0] if labeled_dataset else 'Empty'}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"5UzR4LqKwvbB","executionInfo":{"status":"ok","timestamp":1779041255852,"user_tz":-420,"elapsed":46,"user":{"displayName":"Hien Coder","userId":"07457395390073418186"}},"outputId":"7289ae3b-b19b-4afc-a721-27ba99cdb8fb"},"execution_count":26,"outputs":[{"output_type":"stream","name":"stdout","text":["2026-05-17 18:07:35,690 - FSS_NLP_Phase1 - INFO - [annotate_corpus] - Bắt đầu quá trình gán nhãn BIO tự động (Heuristic Annotation)...\n"]},{"output_type":"stream","name":"stderr","text":["INFO:FSS_NLP_Phase1:Bắt đầu quá trình gán nhãn BIO tự động (Heuristic Annotation)...\n"]},{"output_type":"stream","name":"stdout","text":["2026-05-17 18:07:35,726 - FSS_NLP_Phase1 - INFO - [annotate_corpus] - Hoàn tất gán nhãn cho 3772 mẫu dữ liệu.\n"]},{"output_type":"stream","name":"stderr","text":["INFO:FSS_NLP_Phase1:Hoàn tất gán nhãn cho 3772 mẫu dữ liệu.\n"]},{"output_type":"stream","name":"stdout","text":["2026-05-17 18:07:35,729 - FSS_NLP_Phase1 - INFO - [<cell line: 0>] - Mẫu gán nhãn (Sample 1): [('Cua_đồng', 'B-QTY'), ('xay', 'B-ING'), ('600g', 'B-QTY')]\n"]},{"output_type":"stream","name":"stderr","text":["INFO:FSS_NLP_Phase1:Mẫu gán nhãn (Sample 1): [('Cua_đồng', 'B-QTY'), ('xay', 'B-ING'), ('600g', 'B-QTY')]\n"]}]},{"cell_type":"markdown","source":["### 3.3. Trích xuất đặc trưng ngôn ngữ (Feature Extraction)\n","* Cấu trúc CRF không học qua ma trận nhúng (Word Embeddings) phức tạp mà học thông qua các **Đặc trưng từ vựng (Features)**.\n","* Thiết lập hàm chuyển đổi một token thành một vector đặc trưng cục bộ: kiểm tra định dạng chữ hoa/thường, có phải là chữ số không, các tiền tố (prefix) và hậu tố (suffix) của từ để mô hình suy luận được ngữ cảnh xung quanh."],"metadata":{"id":"s297rWKKwzfH"}},{"cell_type":"code","source":["# 3. Feature Extraction for CRF\n","# -----------------------------------------------------------------------------\n","def word2features(sent: List[tuple], i: int) -> Dict:\n","    \"\"\"\n","    Extracts NLP features for a specific word in a sentence to feed into the CRF model.\n","    \"\"\"\n","    word = sent[i][0]\n","\n","    features = {\n","        'bias': 1.0,\n","        'word.lower()': word.lower(),\n","        'word[-3:]': word[-3:],      # Suffix (helps identify units like \"gam\", \"lít\")\n","        'word[:3]': word[:3],        # Prefix\n","        'word.isupper()': word.isupper(),\n","        'word.istitle()': word.istitle(),\n","        'word.isdigit()': word.isdigit(),\n","        'word.has_underscore()': '_' in word # Feature to recognize compound words from PyVi\n","    }\n","\n","    # Context features: Look at the previous word\n","    if i > 0:\n","        word1 = sent[i-1][0]\n","        features.update({\n","            '-1:word.lower()': word1.lower(),\n","            '-1:word.istitle()': word1.istitle(),\n","            '-1:word.isdigit()': word1.isdigit(),\n","        })\n","    else:\n","        features['BOS'] = True # Beginning of Sentence\n","\n","    # Context features: Look at the next word\n","    if i < len(sent)-1:\n","        word1 = sent[i+1][0]\n","        features.update({\n","            '+1:word.lower()': word1.lower(),\n","            '+1:word.istitle()': word1.istitle(),\n","            '+1:word.isdigit()': word1.isdigit(),\n","        })\n","    else:\n","        features['EOS'] = True # End of Sentence\n","\n","    return features\n","\n","def sent2features(sent: List[tuple]) -> List[Dict]:\n","    return [word2features(sent, i) for i in range(len(sent))]\n","\n","def sent2labels(sent: List[tuple]) -> List[str]:\n","    return [label for token, label in sent]\n","\n","def sent2tokens(sent: List[tuple]) -> List[str]:\n","    return [token for token, label in sent]\n","\n","# Chuẩn bị tập dữ liệu cuối cùng (X_data, y_data)\n","logger.info(\"Đang trích xuất đặc trưng (Feature Extraction) cho toàn bộ tập dữ liệu...\")\n","X_data = [sent2features(s) for s in labeled_dataset]\n","y_data = [sent2labels(s) for s in labeled_dataset]\n","logger.info(\"Trích xuất đặc trưng hoàn tất. Sẵn sàng cho Giai đoạn Huấn luyện.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"h9SBgfxXwz-n","executionInfo":{"status":"ok","timestamp":1779041264389,"user_tz":-420,"elapsed":25,"user":{"displayName":"Hien Coder","userId":"07457395390073418186"}},"outputId":"1be91a1e-5779-4852-c625-b018b75ef6dd"},"execution_count":27,"outputs":[{"output_type":"stream","name":"stdout","text":["2026-05-17 18:07:44,247 - FSS_NLP_Phase1 - INFO - [<cell line: 0>] - Đang trích xuất đặc trưng (Feature Extraction) cho toàn bộ tập dữ liệu...\n"]},{"output_type":"stream","name":"stderr","text":["INFO:FSS_NLP_Phase1:Đang trích xuất đặc trưng (Feature Extraction) cho toàn bộ tập dữ liệu...\n"]},{"output_type":"stream","name":"stdout","text":["2026-05-17 18:07:44,271 - FSS_NLP_Phase1 - INFO - [<cell line: 0>] - Trích xuất đặc trưng hoàn tất. Sẵn sàng cho Giai đoạn Huấn luyện.\n"]},{"output_type":"stream","name":"stderr","text":["INFO:FSS_NLP_Phase1:Trích xuất đặc trưng hoàn tất. Sẵn sàng cho Giai đoạn Huấn luyện.\n"]}]},{"cell_type":"markdown","source":["## GIAI ĐOẠN 4: HUẤN LUYỆN MÔ HÌNH VÀ KIỂM TRA ĐỘ HỘI TỤ (MODEL TRAINING)\n","\n","\n"],"metadata":{"id":"2cfRiw_FP5ey"}},{"cell_type":"markdown","source":["### 4.1. Thiết lập cấu hình thực nghiệm (Experimental Setup)\n","* Phân chia tập dữ liệu nghiêm ngặt theo tỷ lệ: **80% Train Set / 10% Validation Set / 10% Test Set** để chống rò rỉ dữ liệu (Data Leakage).\n","* Cấu hình siêu tham số (Hyperparameters): Lựa chọn bộ tối ưu hóa (Optimizer), thiết lập chu kỳ học tập (Learning Rate Scheduler), hệ số phạt L1/L2 đối với CRF hoặc tỷ lệ Dropout đối với mạng nơ-ron để kiểm soát hiện tượng học vẹt (Overfitting).\n"],"metadata":{"id":"pel68jLeNaNv"}},{"cell_type":"code","source":["# 1. Train / Test Split\n","# -----------------------------------------------------------------------------\n","from sklearn.model_selection import train_test_split\n","\n","logger.info(\"Bắt đầu phân chia tập dữ liệu (Train/Test Split)...\")\n","\n","# Chia dữ liệu theo tỷ lệ 80/20. Cố định random_state để có thể tái lặp kết quả.\n","X_train, X_test, y_train, y_test = train_test_split(\n","    X_data, y_data,\n","    test_size=0.2,\n","    random_state=fss_config.random_seed\n",")\n","\n","logger.info(f\"Kích thước tập Huấn luyện (Train): {len(X_train)} mẫu.\")\n","logger.info(f\"Kích thước tập Kiểm thử (Test): {len(X_test)} mẫu.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"VBfr9FmxIWUe","executionInfo":{"status":"ok","timestamp":1779041415035,"user_tz":-420,"elapsed":618,"user":{"displayName":"Hien Coder","userId":"07457395390073418186"}},"outputId":"26134191-a312-489b-9f00-d5edd4a9bf6b"},"execution_count":28,"outputs":[{"output_type":"stream","name":"stdout","text":["2026-05-17 18:10:14,881 - FSS_NLP_Phase1 - INFO - [<cell line: 0>] - Bắt đầu phân chia tập dữ liệu (Train/Test Split)...\n"]},{"output_type":"stream","name":"stderr","text":["INFO:FSS_NLP_Phase1:Bắt đầu phân chia tập dữ liệu (Train/Test Split)...\n"]},{"output_type":"stream","name":"stdout","text":["2026-05-17 18:10:14,890 - FSS_NLP_Phase1 - INFO - [<cell line: 0>] - Kích thước tập Huấn luyện (Train): 3017 mẫu.\n"]},{"output_type":"stream","name":"stderr","text":["INFO:FSS_NLP_Phase1:Kích thước tập Huấn luyện (Train): 3017 mẫu.\n"]},{"output_type":"stream","name":"stdout","text":["2026-05-17 18:10:14,895 - FSS_NLP_Phase1 - INFO - [<cell line: 0>] - Kích thước tập Kiểm thử (Test): 755 mẫu.\n"]},{"output_type":"stream","name":"stderr","text":["INFO:FSS_NLP_Phase1:Kích thước tập Kiểm thử (Test): 755 mẫu.\n"]}]},{"cell_type":"markdown","source":["### 4.2. Giám sát quá trình huấn luyện và Đánh giá hội tụ (Inference Core Evaluation)\n","* **Vẽ biểu đồ Learning Curves:** Theo dõi liên tục hàm mất mát (Loss Curve) trên cả hai tập Train và Validation qua từng Epoch/Iteration. Mô hình được công nhận là đạt trạng thái hội tụ tối ưu khi khoảng cách giữa Train Loss và Validation Loss tiệm cận mức tối thiểu mà không sinh ra hiện tượng Overfitting.\n","* **Đánh giá trên Validation Set:** Xuất bảng báo cáo phân loại thực thể chi tiết (Classification Report) bao gồm các chỉ số **Strict Precision, Strict Recall, và F1-Score** cho từng lớp nhãn hệ thống độc lập (`INGREDIENT` và `QUANTITY`)."],"metadata":{"id":"7EfYGOtqI3Ak"}},{"cell_type":"code","source":["# 2. CRF Model Initialization & Training\n","# -----------------------------------------------------------------------------\n","logger.info(\"Khởi tạo mô hình Conditional Random Fields (CRF)...\")\n","\n","# Cấu hình siêu tham số cho thuật toán CRF\n","crf_model = sklearn_crfsuite.CRF(\n","    algorithm='lbfgs',      # Thuật toán tối ưu hóa Gradient Descent (rất tốt cho bài toán tối ưu tuyến tính)\n","    c1=0.1,                 # L1 regularization (để ép các trọng số không quan trọng về 0, giúp mô hình nhẹ hơn)\n","    c2=0.1,                 # L2 regularization (để tránh một trọng số trở nên quá lớn, chống Overfitting)\n","    max_iterations=100,     # Số vòng lặp tối đa để hội tụ\n","    all_possible_transitions=True # Đánh giá tất cả các khả năng chuyển đổi giữa các thẻ BIO\n",")\n","\n","logger.info(\"Bắt đầu huấn luyện mô hình (Model Fitting)... Quá trình này có thể mất vài chục giây.\")\n","# Huấn luyện mô hình (Quá trình training sẽ diễn ra nội bộ bằng C/C++ cực kỳ nhanh)\n","try:\n","    crf_model.fit(X_train, y_train)\n","    logger.info(\"Huấn luyện mô hình THÀNH CÔNG!\")\n","except Exception as e:\n","    logger.error(f\"Lỗi trong quá trình huấn luyện: {e}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"9nCKFv8EIYFZ","executionInfo":{"status":"ok","timestamp":1779041419701,"user_tz":-420,"elapsed":456,"user":{"displayName":"Hien Coder","userId":"07457395390073418186"}},"outputId":"198e025c-bea4-4950-d424-4e701dbdb3ec"},"execution_count":29,"outputs":[{"output_type":"stream","name":"stdout","text":["2026-05-17 18:10:19,127 - FSS_NLP_Phase1 - INFO - [<cell line: 0>] - Khởi tạo mô hình Conditional Random Fields (CRF)...\n"]},{"output_type":"stream","name":"stderr","text":["INFO:FSS_NLP_Phase1:Khởi tạo mô hình Conditional Random Fields (CRF)...\n"]},{"output_type":"stream","name":"stdout","text":["2026-05-17 18:10:19,129 - FSS_NLP_Phase1 - INFO - [<cell line: 0>] - Bắt đầu huấn luyện mô hình (Model Fitting)... Quá trình này có thể mất vài chục giây.\n"]},{"output_type":"stream","name":"stderr","text":["INFO:FSS_NLP_Phase1:Bắt đầu huấn luyện mô hình (Model Fitting)... Quá trình này có thể mất vài chục giây.\n"]},{"output_type":"stream","name":"stdout","text":["2026-05-17 18:10:19,578 - FSS_NLP_Phase1 - INFO - [<cell line: 0>] - Huấn luyện mô hình THÀNH CÔNG!\n"]},{"output_type":"stream","name":"stderr","text":["INFO:FSS_NLP_Phase1:Huấn luyện mô hình THÀNH CÔNG!\n"]}]},{"cell_type":"markdown","source":["### 4.3. Đánh giá kiểm duyệt (Evaluation & Metrics Report)\n","* Thực hiện dự đoán trên tập kiểm thử (Test Set) chưa từng xuất hiện trong quá trình huấn luyện.\n","* Xuất báo cáo phân loại chi tiết (Classification Report) đo lường các chỉ số **Precision, Recall, F1-Score**.\n","* **Mục tiêu ràng buộc:** Chỉ số `Macro F1-Score` phải đạt $\\ge$ ngưỡng cấu hình đề ra ở Giai đoạn 1 (Ví dụ: 85%)."],"metadata":{"id":"xwJD8YLVI6ZJ"}},{"cell_type":"code","source":["# 3. Model Evaluation & Metrics Report\n","# -----------------------------------------------------------------------------\n","logger.info(\"Đang tiến hành suy luận (Inference) trên tập kiểm thử (Test Set)...\")\n","\n","# Dự đoán nhãn cho tập Test\n","y_pred = crf_model.predict(X_test)\n","\n","# Loại bỏ nhãn 'O' (Outside) ra khỏi quá trình đánh giá vì nó làm lệch độ chính xác (thường nhãn O chiếm số đông nhưng không quan trọng)\n","labels = list(crf_model.classes_)\n","labels.remove(fss_config.tags.O)\n","\n","logger.info(\"Báo cáo Đánh giá Mô hình (Classification Report):\")\n","\n","# Sử dụng module metrics của sklearn_crfsuite để tính toán các chỉ số\n","evaluation_report = metrics.flat_classification_report(\n","    y_test, y_pred, labels=labels, digits=3\n",")\n","\n","# In báo cáo ra màn hình\n","print(evaluation_report)\n","\n","# Trích xuất F1-Score trung bình (Macro F1) để so sánh với Ràng buộc hệ thống\n","macro_f1 = metrics.flat_f1_score(y_test, y_pred, average='macro', labels=labels)\n","\n","logger.info(f\"-> Macro F1-Score đạt được: {macro_f1 * 100:.2f}%\")\n","\n","if macro_f1 >= fss_config.metrics.target_macro_f1_score:\n","    logger.info(f\"[PASSED] Mô hình ĐẠT CHUẨN yêu cầu hệ thống (>= {fss_config.metrics.target_macro_f1_score * 100}%). Sẵn sàng để Tối ưu hóa (Quantization).\")\n","else:\n","    logger.warning(f\"[FAILED] Mô hình KHÔNG ĐẠT CHUẨN. Cần tinh chỉnh siêu tham số hoặc làm sạch dữ liệu thêm.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"0GmHjED4IZ88","executionInfo":{"status":"ok","timestamp":1779041433665,"user_tz":-420,"elapsed":60,"user":{"displayName":"Hien Coder","userId":"07457395390073418186"}},"outputId":"219f7e3d-bacf-423b-e596-f2554677efb3"},"execution_count":30,"outputs":[{"output_type":"stream","name":"stdout","text":["2026-05-17 18:10:33,488 - FSS_NLP_Phase1 - INFO - [<cell line: 0>] - Đang tiến hành suy luận (Inference) trên tập kiểm thử (Test Set)...\n"]},{"output_type":"stream","name":"stderr","text":["INFO:FSS_NLP_Phase1:Đang tiến hành suy luận (Inference) trên tập kiểm thử (Test Set)...\n"]},{"output_type":"stream","name":"stdout","text":["2026-05-17 18:10:33